# Copy this file to .env and fill it locally.
# Never paste real keys into chat and never commit .env.

# X official API OAuth 1.0a credentials with Read and Write permission
TWITTER_API_KEY=
TWITTER_API_SECRET_KEY=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Start safely. Keep this true until the bot logs look good.
TWITTER_DRY_RUN=true

# Conservative launch settings
TWITTER_POST_INTERVAL=3600
TWITTER_REPLY_CHANCE=0.25
TWITTER_SEARCH_KEYWORDS=MCP,FCFS,breadlines,Solana,proposers

# Model provider. Fill the one you plan to use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
BOT_MODEL=gpt-4.1-mini
BOT_AUTO_POST=false
BOT_AUTO_REPLY=false
BOT_APPROVAL_MODE=true
BOT_MENTIONS_ENABLED=true
BOT_RECEIPTS_ENABLED=true
BOT_RECEIPT_AUTO_REPLY=false
BOT_RECEIPT_POLL_INTERVAL_MS=60000
BOT_MAX_RECEIPT_DRAFTS_PER_CYCLE=5
BOT_RECEIPT_REPLY_LINK=true
BOT_CONTENT_POST_ENABLED=false
BOT_CONTENT_CHECK_INTERVAL_MS=60000
BOT_CONTENT_MIN_INTERVAL_MINUTES=180
BOT_CONTENT_MAX_INTERVAL_MINUTES=420
BOT_CONTENT_LINK_EVERY_N_POSTS=4
BOT_CONTENT_USE_OPENAI=false
BOT_CONTENT_OPENAI_CANDIDATES=6
BOT_BACKFILL_MENTIONS=false
BOT_THREAD_MENTION_SEARCH_ENABLED=true
BOT_SEARCH_ENABLED=false
BOT_ALLOW_ACCOUNT_TAGGING=false
BOT_MAX_REPLIES_PER_CYCLE=3
BOT_REPLY_SCORE_THRESHOLD=75
BOT_TOLY_SIGNAL_ENABLED=false
BOT_TOLY_HANDLE=toly
BOT_TOLY_SIGNAL_TERMS=MCP,FCFS,bread line,breadlines,proposer,leader monopoly
BOT_TOLY_SIGNAL_DRAFTS_PER_CYCLE=2
BOT_CYCLE_MINUTES_MIN=20
BOT_CYCLE_MINUTES_MAX=45
BOT_MIN_POST_INTERVAL_MINUTES=180
BOT_MAX_POST_INTERVAL_MINUTES=420
BOT_LINK_EVERY_N_POSTS=3
BOT_HUMOR_LEVEL=medium

# Draft Inbox v0
# If DATABASE_URL is set, receipt/reply drafts are stored in Postgres.
# If absent, the bot falls back to data/replies.json for local development.
BOT_DRAFT_STORE=auto
DATABASE_URL=
BOT_DATABASE_SSL=false

# BreadLines constants
BREADLINES_SITE=https://breadlinesmarkets.com
BREADLINES_RECEIPT_API_URL=https://breadlinesmarkets.com/api/receipt
# Optional. Use {signature} if/when the site has shareable receipt URLs.
BREADLINES_RECEIPT_URL_TEMPLATE=
BREADLINES_CA=8cLSy3rjyCuVzzE1PuQ7AwALQNERrTZx9T8R52pRpump
BREADLINES_OPERATOR_HANDLE=

# Optional but strongly recommended. Prevents posting if tokens belong to the wrong X account.
TWITTER_EXPECTED_USERNAME=Breadlinebot

# Local database path for elizaOS/pglite setups
PGLITE_DATA_DIR=.eliza/.elizadb
